# Local Coder 5090 — environment configuration
# Copy to .env and adjust. NOTHING here is required for local-only operation:
# with Ollama running on :11434 and no keys set, the server works out of the box.
# .env is gitignored — never commit real keys.

# ─────────────────────────────────────────────────────────────────────────────
# Core: models & Ollama backend
# ─────────────────────────────────────────────────────────────────────────────
# Ollama OpenAI-compatible base URL
LOCAL_CODER_MODEL_BASE=http://localhost:11434
# Primary model (coding + reasoning). ~20 GB VRAM on the RTX 5090.
LOCAL_CODER_MODEL=qwen3:32b
# Fast tier for quick completions / tool calls. Gemma 4 edge model, ~5 GB.
LOCAL_CODER_FAST_MODEL=gemma4:latest

# ─────────────────────────────────────────────────────────────────────────────
# Filesystem roots (Windows defaults shown)
# ─────────────────────────────────────────────────────────────────────────────
LOCAL_CODER_HOME=C:\Users\techai\local-coder
# Defaults to $LOCAL_CODER_HOME\workspace when unset.
# LOCAL_CODER_WORKSPACE=
# Where generated skills are written.
# LOCAL_CODER_SKILL_GEN=
# Extra directories the tool sandbox may operate in (semicolon-separated).
# By default only WORKSPACE, the home root, and the repo root are permitted.
# LOCAL_CODER_ALLOWED_ROOTS=D:\projects\my-repo;D:\projects\other

# ─────────────────────────────────────────────────────────────────────────────
# Security & limits
# ─────────────────────────────────────────────────────────────────────────────
# If set, every request must send a matching X-API-Key (or Authorization: Bearer).
# Leave unset for trusted localhost-only use. The CLI reads this same var.
# LOCAL_CODER_API_KEY=change-me-to-a-long-random-string
# Token-bucket rate limiting (per source IP).
LOCAL_CODER_RATE_LIMIT=60
LOCAL_CODER_RATE_BURST=20
# Comma-separated Docker MCP tool allowlist (opt-in).
# LOCAL_CODER_DOCKER_MCP_ALLOWED=

# ─────────────────────────────────────────────────────────────────────────────
# Web search (optional — falls back to HTML scraping if no key)
# ─────────────────────────────────────────────────────────────────────────────
# BRAVE_API_KEY=
# BRAVE_SEARCH_API_KEY=
# Provider chain, tried in order.
# LOCAL_CODER_WEB_SEARCH_PROVIDER=brave-api,brave-html,duckduckgo-html,bing-html

# ─────────────────────────────────────────────────────────────────────────────
# Cloud fallback backends (optional — chain: Ollama → OpenRouter → Bedrock → NIM)
# Each only activates when its key is present.
# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=qwen/qwen3-32b
# AWS Bedrock (requires boto3 + AWS creds via the standard chain)
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# NVIDIA NIM
# NVIDIA_API_KEY=
# NIM_BASE=https://integrate.api.nvidia.com/v1

# ─────────────────────────────────────────────────────────────────────────────
# Remote execution (spark_exec tool) — optional, opt-in per node.
# The tool looks up LOCAL_CODER_SSH_<NODE> (node name upper-cased, non-alnum
# stripped). Add a _JUMP suffix for an SSH bastion/-J host.
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL_CODER_SSH_SPARK1=user@10.0.0.1
# LOCAL_CODER_SSH_SPARK2=user@10.0.0.2
# LOCAL_CODER_SSH_SPARK2_JUMP=user@jumphost
